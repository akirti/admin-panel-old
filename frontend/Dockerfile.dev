# Frontend Development Dockerfile with Webpack dev server
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Create jira-dashboard placeholder for npm install (volume will override at runtime)
RUN mkdir -p /jira-dashboard && echo '{"name":"jira-dashboard","version":"1.0.0","main":"src/index.js"}' > /jira-dashboard/package.json

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy source code
COPY . .

# Expose dev server port
EXPOSE 5173

# Set environment variable for API proxy target in Docker network
ENV WEBPACK_PROXY_TARGET=http://backend:8000

# Start Webpack dev server
CMD ["npm", "run", "dev"]
